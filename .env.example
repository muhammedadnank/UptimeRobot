# ── Telegram MTProto Credentials ────────────────────────
# Get API_ID and API_HASH from https://my.telegram.org
# → Log in → API Development Tools → Create application
API_ID=
API_HASH=

# ── Bot Token ────────────────────────────────────────────
# Get from Telegram → @BotFather → /newbot
BOT_TOKEN=

# ── MongoDB ──────────────────────────────────────────────
# MongoDB Atlas free tier: https://cloud.mongodb.com
# → New Project → Create Cluster (M0 Free)
# → Connect → Drivers → copy the connection string
# Replace <password> with your DB user password
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

# NOTE: UPTIMEROBOT_API_KEY is no longer needed here.
# Each user sets their own key via /setkey command in the bot.
